---
import Layout from '../layouts/Layout.astro';

const resources = [
  {
    title: 'Project Recovery Pack',
    description:
      'For project managers stepping into a project that needs stabilising. Recovery assessment, stakeholder alignment, replan and governance reset artefacts.',
    href: 'https://lavelleptyltd.com.au/pmo-resources#project-recovery-pack',
  },
  {
    title: 'Business Case Pack',
    description:
      'End-to-end business case structure including problem definition, options analysis, benefits, costs, risks and approval routing.',
    href: 'https://lavelleptyltd.com.au/pmo-resources#business-case-pack',
  },
  {
    title: 'Procurement Pack',
    description:
      'RFP planning, evaluation criteria, scoring frameworks, BAFO process and delegate approval templates.',
    href: 'https://lavelleptyltd.com.au/pmo-resources#procurement-pack',
  },
  {
    title: 'Steering Committee Pack',
    description:
      'Steering committee charter, meeting cadence, status report template, RAID summary and decision log.',
    href: 'https://lavelleptyltd.com.au/pmo-resources#steering-committee-pack',
  },
];
---

<Layout
  title="Resources | Sky Lavelle"
  description="Project management resources, PMO templates and delivery frameworks developed by Sky Lavelle and published through Lavelle Pty Ltd."
>
  <section class="bg-warm-950 text-white py-14 lg:py-20">
    <div class="container">
      <div class="max-w-2xl">
        <h1 class="text-3xl lg:text-4xl font-bold text-white mb-4">Resources</h1>
        <p class="text-lg text-warm-200 leading-relaxed">
          PMO templates, frameworks and recovery tools developed from years of enterprise delivery practice.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl mb-10">
        <p class="text-warm-800 leading-relaxed mb-4">
          Over years of project delivery work I have built up a set of PMO templates, frameworks and recovery tools that have proven useful across multiple organisations and project types.
        </p>
        <p class="text-warm-800 leading-relaxed">
          These resources are published and maintained through Lavelle Pty Ltd, the company I run. The links below take you to the relevant product pages.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-12">
        {resources.map((resource) => (
          <a
            href={resource.href}
            class="group flex flex-col p-6 rounded-lg border border-warm-200 bg-white hover:border-ochre-400 hover:shadow-sm transition-all"
          >
            <h2 class="text-base font-semibold text-warm-900 group-hover:text-ochre-600 mb-2 transition-colors">
              {resource.title}
            </h2>
            <p class="text-sm text-warm-700 leading-relaxed flex-1 mb-4">{resource.description}</p>
            <span class="inline-flex items-center text-sm font-medium text-ochre-600 group-hover:text-warm-900">
              View resource
              <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="rounded-lg border border-warm-200 bg-warm-50 p-6 max-w-2xl">
        <p class="text-sm text-warm-700 leading-relaxed mb-4">
          All PMO resources, the delivery framework and consulting enquiries are managed through Lavelle Pty Ltd.
        </p>
        <a
          href="https://lavelleptyltd.com.au"
          class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-warm-800 hover:bg-warm-900 rounded-md transition-colors"
          data-ga-event="resource_cta_click"
          data-ga-label="visit-lavelle-pty-ltd"
        >
          Visit Lavelle Pty Ltd
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

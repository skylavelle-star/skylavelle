---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<Layout
  title="Writing | Sky Lavelle"
  description="Practical writing on project delivery, governance, recovery and enterprise technology programs."
>
  <section class="bg-warm-950 text-white py-14 lg:py-20">
    <div class="container">
      <div class="max-w-2xl">
        <h1 class="text-3xl lg:text-4xl font-bold text-white mb-4">Writing</h1>
        <p class="text-lg text-warm-200 leading-relaxed">
          Practical writing on project delivery, governance, recovery and enterprise technology programs.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {sorted.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {sorted.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/articles/${article.id}`}
              publishDate={article.data.publishDate}
              category={article.data.category}
              featured={article.data.featured}
            />
          ))}
        </div>
      ) : (
        <p class="text-warm-700">Articles coming soon.</p>
      )}

      <div class="mt-12 rounded-lg border border-warm-200 bg-warm-50 p-6 max-w-xl">
        <p class="text-sm font-semibold text-warm-900 mb-2">PMO templates and free tools</p>
        <p class="text-sm text-warm-700 leading-relaxed mb-4">
          Practical templates, free checklists and PMO resources are published and maintained through Lavelle Pty Ltd.
        </p>
        <a
          href="https://lavelleptyltd.com.au"
          class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-warm-800 hover:bg-warm-900 rounded-md transition-colors"
          data-ga-event="resource_cta_click"
          data-ga-label="visit-lavelle-pty-ltd"
          target="_blank"
          rel="noopener noreferrer"
        >
          Visit Lavelle Pty Ltd
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

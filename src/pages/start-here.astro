---
import Layout from '../layouts/Layout.astro';

const routes = [
  {
    heading: 'My project is failing',
    description:
      'Delivery dates keep slipping, stakeholders have lost confidence, or the program has stopped producing results. You need an honest assessment and a credible path forward.',
    links: [
      { label: 'Read: How to rescue a failing IT project', href: '/articles/how-to-rescue-a-failing-it-project', type: 'article' },
      { label: 'Free: Project Recovery Checklist', href: 'https://lavelleptyltd.com.au/free-tools/project-recovery-checklist', type: 'free', external: true },
      { label: 'Template: Project Recovery Pack', href: 'https://lavelleptyltd.com.au/templates/project-recovery-pack', type: 'product', external: true },
      { label: 'Advisory: Send an Enquiry', href: '/contact?service=project-recovery', type: 'advisory' },
    ],
    icon: '↗',
    accent: 'border-red-200 bg-red-50',
    accentIcon: 'text-red-600',
  },
  {
    heading: 'I need to write a business case',
    description:
      'A significant technology investment needs approval. You need an investment proposal that presents a genuine options analysis and a financial case that will survive scrutiny.',
    links: [
      { label: 'Read: How to write a technology business case', href: '/articles/how-to-write-a-technology-business-case', type: 'article' },
      { label: 'Free: Business Case Readiness Checklist', href: 'https://lavelleptyltd.com.au/free-tools', type: 'free', external: true },
      { label: 'Template: Business Case Pack', href: 'https://lavelleptyltd.com.au/templates/business-case-pack', type: 'product', external: true },
      { label: 'Advisory: Send an Enquiry', href: '/contact?service=business-case', type: 'advisory' },
    ],
    icon: '◉',
    accent: 'border-blue-200 bg-blue-50',
    accentIcon: 'text-blue-600',
  },
  {
    heading: 'I need to run a procurement',
    description:
      'A technology acquisition needs a defensible evaluation process. You need structured criteria, a probity-sound evaluation, and documentation that supports the delegate approval decision.',
    links: [
      { label: 'Read: How to run a restricted RFP', href: '/articles/how-to-run-a-restricted-rfp', type: 'article' },
      { label: 'Free: Procurement Evaluation Checklist', href: 'https://lavelleptyltd.com.au/free-tools', type: 'free', external: true },
      { label: 'Template: Procurement Pack', href: 'https://lavelleptyltd.com.au/templates/procurement-pack', type: 'product', external: true },
      { label: 'Advisory: Send an Enquiry', href: '/contact?service=procurement', type: 'advisory' },
    ],
    icon: '◈',
    accent: 'border-amber-200 bg-amber-50',
    accentIcon: 'text-amber-600',
  },
  {
    heading: 'My steering committee reporting is not working',
    description:
      'The committee is not getting accurate information. Reports are too long, RAG ratings are inflated, risks are listed but not escalated, and meetings are not producing decisions.',
    links: [
      { label: 'Read: How to build a steering committee report', href: '/articles/how-to-build-a-steering-committee-report', type: 'article' },
      { label: 'Free: Steering Committee Checklist', href: 'https://lavelleptyltd.com.au/free-tools', type: 'free', external: true },
      { label: 'Template: Steering Committee Pack', href: 'https://lavelleptyltd.com.au/templates/steering-committee-pack', type: 'product', external: true },
      { label: 'Advisory: Send an Enquiry', href: '/contact?service=reporting', type: 'advisory' },
    ],
    icon: '▦',
    accent: 'border-purple-200 bg-purple-50',
    accentIcon: 'text-purple-600',
  },
  {
    heading: 'I need senior advisory support',
    description:
      'The situation requires more than a template. You need an experienced senior PM who can assess the program, reset the stakeholder position and provide delivery leadership through a difficult period.',
    links: [
      { label: 'View all services', href: '/services', type: 'article' },
      { label: 'About Sky Lavelle', href: '/about', type: 'article' },
      { label: 'Send an enquiry', href: '/contact', type: 'advisory' },
    ],
    icon: '◆',
    accent: 'border-warm-200 bg-warm-100',
    accentIcon: 'text-ochre-600',
  },
];

const linkStyles: Record<string, string> = {
  article: 'text-warm-800 hover:text-ochre-600',
  free: 'text-emerald-700 hover:text-emerald-900 font-medium',
  product: 'text-ochre-600 hover:text-warm-900 font-medium',
  advisory: 'text-white bg-warm-800 hover:bg-warm-900 px-3 py-1.5 rounded-md text-sm',
};
---

<Layout
  title="Start Here | Sky Lavelle"
  description="Choose the delivery situation you are dealing with and find the right article, checklist, template or advisory support."
>
  <section class="bg-warm-950 text-white py-14 lg:py-20">
    <div class="container">
      <div class="max-w-2xl">
        <h1 class="text-3xl lg:text-4xl font-bold text-white mb-4">Start Here</h1>
        <p class="text-lg text-warm-200">
          Choose the situation that best matches the delivery problem you are dealing with.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="space-y-6">
        {routes.map((route) => (
          <div
            class:list={['rounded-lg border p-6 lg:p-8', route.accent]}
            data-ga-event="start_here_card_click"
            data-ga-label={route.heading}
          >
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
              <div class="lg:col-span-1">
                <div class="flex items-center gap-3 mb-3">
                  <span class:list={['text-xl font-bold', route.accentIcon]} aria-hidden="true">{route.icon}</span>
                  <h2 class="text-lg font-bold text-warm-900">{route.heading}</h2>
                </div>
                <p class="text-sm text-warm-700 leading-relaxed">{route.description}</p>
              </div>
              <div class="lg:col-span-2">
                <p class="text-xs font-semibold text-warm-700 uppercase tracking-wider mb-3">Where to start</p>
                <div class="flex flex-wrap gap-3">
                  {route.links.map((link) => (
                    <a
                      href={link.href}
                      {...('external' in link && link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                      class:list={[
                        'inline-flex items-center text-sm transition-colors',
                        linkStyles[link.type] || linkStyles.article,
                      ]}
                    >
                      {link.type === 'free' && (
                        <span class="inline-flex items-center text-xs font-semibold bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded mr-1.5">Free</span>
                      )}
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 pt-8 border-t border-warm-200 text-center">
        <p class="text-warm-700 mb-4">Not sure where to start? Send a short description of your situation.</p>
        <a
          href="/contact"
          class="inline-flex items-center px-6 py-3 text-base font-medium text-white bg-warm-800 hover:bg-warm-900 rounded-md transition-colors"
          data-ga-event="advisory_offer_click"
          data-ga-label="start-here-bottom"
        >
          Send an enquiry
        </a>
      </div>
    </div>
  </section>
</Layout>

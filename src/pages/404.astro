---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Sky Lavelle"
  description="The page you are looking for does not exist."
  noindex
>
  <section class="section min-h-[60vh] flex items-center">
    <div class="container text-center">
      <p class="text-sm font-semibold text-ochre-600 uppercase tracking-wider mb-4">404</p>
      <h1 class="text-4xl lg:text-5xl font-bold text-warm-900 mb-4">Page not found</h1>
      <p class="text-lg text-warm-700 mb-8 max-w-md mx-auto">
        The page you are looking for does not exist or may have been moved.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center px-6 py-3 text-base font-medium text-white bg-warm-800 hover:bg-warm-900 rounded-md transition-colors"
        >
          Back to home
        </a>
        <a
          href="/articles"
          class="inline-flex items-center px-6 py-3 text-base font-medium text-warm-800 border border-warm-700 hover:bg-warm-100 rounded-md transition-colors"
        >
          Browse articles
        </a>
      </div>

      <div class="mt-12 pt-8 border-t border-warm-200 max-w-sm mx-auto">
        <p class="text-sm text-warm-700 mb-4">Looking for something specific?</p>
        <div class="flex flex-wrap justify-center gap-3 text-sm">
          {
            [
              { label: 'Services', href: '/services' },
              { label: 'Articles', href: '/articles' },
              { label: 'About', href: '/about' },
              { label: 'Contact', href: '/contact' },
            ].map((link) => (
              <a href={link.href} class="text-ochre-600 hover:text-warm-900 underline">
                {link.label}
              </a>
            ))
          }
        </div>
        <p class="text-sm text-warm-700 mt-4">
          Looking for PMO resources or templates?
          <a href="https://lavelleptyltd.com.au/pmo-resources" target="_blank" rel="noopener noreferrer" class="text-ochre-600 hover:text-warm-900 underline ml-1">Visit Lavelle Pty Ltd</a>
        </p>
      </div>
    </div>
  </section>
</Layout>

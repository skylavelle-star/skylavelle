---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Business Case Pack | Sky Lavelle"
  canonicalURL="https://lavelleptyltd.com.au/templates/business-case-pack"
  noindex
>
  <section class="section min-h-[50vh] flex items-center">
    <div class="container max-w-2xl">
      <p class="text-sm font-semibold text-ochre-600 uppercase tracking-wider mb-3">Moved</p>
      <h1 class="text-2xl font-bold text-warm-900 mb-4">Business Case Pack</h1>
      <p class="text-warm-700 leading-relaxed mb-6">
        The Business Case Pack is now available through Lavelle Pty Ltd.
      </p>
      <a
        href="https://lavelleptyltd.com.au/templates/business-case-pack"
        class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-warm-800 hover:bg-warm-900 rounded-md transition-colors"
      >
        View at Lavelle Pty Ltd
        <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </section>
</Layout>

---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  seoTitle?: string;
  seoDescription?: string;
  ogImage?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  seoTitle,
  seoDescription,
  ogImage,
  canonicalURL,
  noindex = false,
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <slot name="head" />
    <link rel="alternate" type="application/rss+xml" title="Sky Lavelle Articles" href="/rss.xml" />

    <SEO
      title={seoTitle || title}
      description={seoDescription || description}
      ogImage={ogImage}
      canonicalURL={canonicalURL}
      noindex={noindex}
    />

    {
      gaId && (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
          />
          <script define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <!-- GA event delegation: fires gtag events for any element with data-ga-event attribute -->
    <script>
      document.addEventListener('click', (e) => {
        const el = (e.target as Element)?.closest('[data-ga-event]');
        if (!el || typeof window.gtag !== 'function') return;
        const event = el.getAttribute('data-ga-event') ?? '';
        const params: Record<string, string> = {};
        for (const attr of Array.from(el.attributes)) {
          if (attr.name.startsWith('data-ga-') && attr.name !== 'data-ga-event') {
            params[attr.name.replace('data-ga-', '')] = attr.value;
          }
        }
        window.gtag('event', event, params);
      });
    </script>
  </body>
</html>

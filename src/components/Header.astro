---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Articles', href: '/articles' },
  { label: 'Resources', href: '/resources' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-warm-200 sticky top-0 z-50">
  <div class="container">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 group" aria-label="Sky Lavelle - Home">
        <span class="text-xl font-bold text-warm-900 group-hover:text-ochre-600 transition-colors">
          Sky Lavelle
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 text-sm font-medium rounded-md transition-colors',
                currentPath === link.href || currentPath.startsWith(link.href + '/')
                  ? 'text-ochre-600 bg-warm-100'
                  : 'text-warm-900 hover:text-ochre-600 hover:bg-warm-100',
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden lg:flex items-center">
        <a
          href="/contact"
          class="inline-flex items-center px-[0.9rem] py-[0.4rem] text-sm font-medium text-ochre-600 bg-transparent border border-ochre-600 hover:bg-ochre-600 hover:text-warm-50 rounded-md transition-colors"
        >
          Contact
        </a>
      </div>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden p-2 rounded-md text-warm-800 hover:text-warm-900 hover:bg-warm-100 transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle navigation menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path id="menu-open-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-warm-200 bg-white">
    <nav class="container py-4 flex flex-col gap-1" aria-label="Mobile navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-md transition-colors',
              currentPath === link.href || currentPath.startsWith(link.href + '/')
                ? 'text-ochre-600 bg-warm-100'
                : 'text-warm-900 hover:text-ochre-600 hover:bg-warm-100',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <div class="pt-3 mt-2 border-t border-warm-200">
        <a
          href="/contact"
          class="block px-[0.9rem] py-[0.4rem] text-sm font-medium text-center text-ochre-600 bg-transparent border border-ochre-600 hover:bg-ochre-600 hover:text-warm-50 rounded-md transition-colors"
        >
          Contact
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>

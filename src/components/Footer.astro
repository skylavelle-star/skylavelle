---
const currentYear = new Date().getFullYear();

const footerLinks = {
  Services: [
    { label: 'Project Recovery', href: '/services/project-recovery' },
    { label: 'Enterprise Technology Delivery', href: '/services/enterprise-technology-delivery' },
    { label: 'Procurement and Governance', href: '/services/procurement-and-governance' },
    { label: 'Business Case Development', href: '/services/business-case-development' },
    { label: 'Steering Committee Reporting', href: '/services/steering-committee-reporting' },
  ],
  Related: [
    { label: 'Lavelle Pty Ltd', href: 'https://lavelleptyltd.com.au', external: true },
    { label: 'PMO Resources', href: 'https://lavelleptyltd.com.au/pmo-resources', external: true },
    { label: 'Delivery Framework', href: 'https://lavelleptyltd.com.au/delivery-framework', external: true },
  ],
  'Sky Lavelle': [
    { label: 'About', href: '/about' },
    { label: 'Resources', href: '/resources' },
    { label: 'Articles', href: '/articles' },
    { label: 'Contact', href: '/contact' },
  ],
};
---

<footer class="bg-warm-950 text-warm-200">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="font-serif text-xl font-bold text-white hover:text-warm-200 transition-colors">
          Sky Lavelle
        </a>
        <p class="mt-4 text-sm leading-relaxed" style="color: rgba(250,248,245,0.45)">
          I am a senior project delivery consultant. PMO resources, templates and commercial enquiries are managed through Lavelle Pty Ltd.
        </p>
        <p class="mt-4 text-sm" style="color: rgba(250,248,245,0.3)">
          Based in Australia.
        </p>
        <div class="mt-6">
          <a
            href="https://lavelleptyltd.com.au/consulting"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-warm-800 hover:bg-warm-700 rounded-md transition-colors font-sans"
          >
            Engage Lavelle Pty Ltd
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {
        Object.entries(footerLinks).map(([heading, links]) => (
          <div>
            <h3 class="font-sans text-xs font-semibold text-white uppercase tracking-wider mb-4">
              {heading}
            </h3>
            <ul class="space-y-2">
              {links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    {...('external' in link && link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    class="text-sm hover:text-white transition-colors font-sans"
                    style="color: rgba(250,248,245,0.45)"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 pt-8 border-t border-warm-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm font-sans" style="color: rgba(250,248,245,0.3)">
        &copy; {currentYear} Sky Lavelle. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="https://linkedin.com/in/skylavelle"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm hover:text-white transition-colors font-sans"
          style="color: rgba(250,248,245,0.3)"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href="/privacy" class="text-sm hover:text-white transition-colors font-sans" style="color: rgba(250,248,245,0.3)">Privacy</a>
      </div>
    </div>
  </div>
</footer>

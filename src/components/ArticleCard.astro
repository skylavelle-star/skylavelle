---
interface Props {
  title: string;
  description: string;
  href: string;
  publishDate: Date;
  category?: string;
  featured?: boolean;
}

const { title, description, href, publishDate, category, featured = false } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article
  class:list={[
    'group flex flex-col rounded-lg border overflow-hidden transition-all duration-200',
    featured
      ? 'border-ochre-300/40 hover:border-ochre-400/60 hover:shadow-sm'
      : 'border-warm-200 hover:border-warm-200 hover:shadow-sm',
  ]}
>
  <div class="p-6 flex flex-col flex-1 bg-warm-50">
    <div class="flex items-center gap-3 mb-3">
      {
        category && (
          <span class="text-xs font-semibold uppercase tracking-wider text-ochre-600 font-sans">
            {category}
          </span>
        )
      }
      <time class="text-xs text-warm-700/50 font-sans" datetime={publishDate.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <h3 class="text-base font-semibold text-warm-900 mb-2 group-hover:text-ochre-600 transition-colors leading-snug">
      <a href={href} class="stretched-link">
        {title}
      </a>
    </h3>

    <p class="text-sm text-warm-700 leading-relaxed flex-1">
      {description}
    </p>

    <div class="mt-4 text-sm font-medium text-ochre-600 flex items-center gap-1 group-hover:gap-2 transition-all font-sans">
      Read article
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</article>

---
interface Props {
  title: string;
  description: string;
  url: string;
}

const { title, description, url } = Astro.props;
---

<aside class="my-10 rounded-lg border border-warm-200 bg-warm-100 p-5">
  <p class="text-xs font-semibold text-warm-700 uppercase tracking-wider mb-2">Related resource</p>
  <h2 class="text-sm font-semibold text-warm-900 mb-1">{title}</h2>
  <p class="text-xs text-warm-700 leading-relaxed mb-3">{description}</p>
  <a
    href={url}
    class="inline-flex items-center text-sm font-medium text-ochre-600 hover:text-ochre-700 transition-colors"
    data-ga-event="resource_cta_click"
    data-ga-label={title}
  >
    View resource
    <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</aside>

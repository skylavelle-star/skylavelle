---
interface Props {
  type: 'checklist' | 'businesscase' | 'scorecard' | 'dashboard' | 'riskregister' | 'costbenefit';
  label?: string;
}

const { type, label } = Astro.props;

const labels: Record<string, string> = {
  checklist: label || 'Project Recovery Checklist',
  businesscase: label || 'Technology Business Case',
  scorecard: label || 'Procurement Evaluation Scorecard',
  dashboard: label || 'Steering Committee Dashboard',
  riskregister: label || 'Risk Register',
  costbenefit: label || 'Cost-Benefit Model',
};

const docLabel = labels[type];
---

<div class="relative bg-white rounded-lg border border-slate-200 shadow-sm overflow-hidden select-none" aria-hidden="true">
  <!-- Document chrome -->
  <div class="bg-slate-100 border-b border-slate-200 px-3 py-2 flex items-center gap-1.5">
    <div class="w-2.5 h-2.5 rounded-full bg-slate-300"></div>
    <div class="w-2.5 h-2.5 rounded-full bg-slate-300"></div>
    <div class="w-2.5 h-2.5 rounded-full bg-slate-300"></div>
    <span class="ml-2 text-xs text-slate-400 font-medium truncate">{docLabel}.docx</span>
  </div>

  <!-- Document body -->
  <div class="p-4 space-y-3">

    {type === 'checklist' && (
      <div class="space-y-2.5">
        <div class="flex items-center gap-2 pb-2 border-b border-slate-100">
          <div class="w-3 h-3 rounded-sm bg-warm-800 flex items-center justify-center shrink-0">
            <svg class="w-2 h-2 text-white" fill="none" viewBox="0 0 12 12" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2 6l3 3 5-5" />
            </svg>
          </div>
          <div class="h-2 bg-slate-800 rounded w-32"></div>
        </div>
        {['Delivery confidence', 'Governance health', 'Stakeholder alignment', 'Financial position', 'Vendor performance', 'Team capacity'].map((item, i) => (
          <div class="flex items-center gap-2">
            <div class:list={['w-3 h-3 rounded-sm shrink-0 flex items-center justify-center', i < 4 ? 'bg-warm-800' : 'border border-slate-300']}>
              {i < 4 && (
                <svg class="w-2 h-2 text-white" fill="none" viewBox="0 0 12 12" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2 6l3 3 5-5" />
                </svg>
              )}
            </div>
            <div class:list={['h-1.5 rounded', i < 4 ? 'bg-slate-400' : 'bg-slate-200']} style={`width: ${60 + (i * 11) % 35}%`}></div>
          </div>
        ))}
        <div class="pt-2 border-t border-slate-100 flex justify-between items-center">
          <div class="h-1.5 bg-slate-200 rounded w-20"></div>
          <div class="text-xs font-semibold text-ochre-600">4 / 6</div>
        </div>
      </div>
    )}

    {type === 'businesscase' && (
      <div class="space-y-2.5">
        <div class="h-3 bg-warm-900 rounded w-3/4"></div>
        <div class="h-1.5 bg-slate-200 rounded w-full"></div>
        <div class="h-1.5 bg-slate-200 rounded w-5/6"></div>
        <div class="mt-3 space-y-1.5">
          {['Strategic context', 'Options analysis', 'Recommended option', 'Financial case', 'Implementation risk', 'Benefits realisation'].map((section) => (
            <div class="flex items-center gap-2 p-1.5 rounded bg-slate-50">
              <div class="w-1 h-4 rounded bg-ochre-600 shrink-0"></div>
              <div class="h-1.5 bg-slate-300 rounded flex-1"></div>
              <div class="h-1.5 bg-slate-200 rounded w-8"></div>
            </div>
          ))}
        </div>
        <div class="mt-2 p-2 bg-warm-100 rounded border border-warm-200">
          <div class="h-1.5 bg-ochre-400 rounded w-24 mb-1"></div>
          <div class="h-1.5 bg-warm-200 rounded w-full"></div>
        </div>
      </div>
    )}

    {type === 'scorecard' && (
      <div class="space-y-1.5">
        <div class="grid grid-cols-5 gap-1 text-xs pb-1 border-b border-slate-200">
          <div class="col-span-2 h-1.5 bg-slate-400 rounded"></div>
          <div class="h-1.5 bg-slate-300 rounded"></div>
          <div class="h-1.5 bg-slate-300 rounded"></div>
          <div class="h-1.5 bg-slate-300 rounded"></div>
        </div>
        {[
          [70, 8, 6, 9],
          [20, 7, 8, 6],
          [10, 9, 7, 8],
        ].map((row) => (
          <div class="grid grid-cols-5 gap-1 items-center py-0.5">
            <div class="col-span-2 h-1.5 bg-slate-200 rounded" style={`width: ${row[0]}%`}></div>
            {row.slice(1).map((score) => (
              <div class:list={['h-4 rounded text-center flex items-center justify-center', score >= 8 ? 'bg-emerald-100' : score >= 6 ? 'bg-amber-50' : 'bg-slate-100']}>
                <span class="text-xs font-semibold" style="font-size:9px">{score}</span>
              </div>
            ))}
          </div>
        ))}
        <div class="pt-1.5 border-t border-slate-200 grid grid-cols-5 gap-1">
          <div class="col-span-2 h-1.5 bg-warm-200 rounded w-16"></div>
          <div class="h-4 rounded bg-emerald-600 flex items-center justify-center">
            <span class="text-white font-bold" style="font-size:9px">8.1</span>
          </div>
          <div class="h-4 rounded bg-amber-400 flex items-center justify-center">
            <span class="text-white font-bold" style="font-size:9px">7.3</span>
          </div>
          <div class="h-4 rounded bg-slate-400 flex items-center justify-center">
            <span class="text-white font-bold" style="font-size:9px">7.7</span>
          </div>
        </div>
      </div>
    )}

    {type === 'dashboard' && (
      <div class="space-y-2">
        <div class="grid grid-cols-3 gap-1.5">
          {[
            { label: 'Delivery', color: 'bg-emerald-500' },
            { label: 'Budget', color: 'bg-amber-400' },
            { label: 'Risk', color: 'bg-red-500' },
          ].map((item) => (
            <div class="rounded bg-slate-50 border border-slate-200 p-1.5 text-center">
              <div class={`w-3 h-3 rounded-full mx-auto mb-1 ${item.color}`}></div>
              <div class="h-1 bg-slate-200 rounded w-full"></div>
            </div>
          ))}
        </div>
        <div class="space-y-1.5 pt-1">
          {['Milestone progress', 'Budget tracking', 'Open risks', 'Decisions required'].map((row, i) => (
            <div class="flex items-center gap-2">
              <div class="h-1.5 bg-slate-300 rounded w-24 shrink-0"></div>
              <div class="flex-1 h-2 bg-slate-100 rounded overflow-hidden">
                <div class:list={['h-full rounded', i === 2 ? 'bg-red-300' : i === 1 ? 'bg-amber-300' : 'bg-emerald-300']} style={`width: ${[72,55,40,60][i]}%`}></div>
              </div>
              <div class="text-xs font-medium text-slate-500 w-6 text-right" style="font-size:9px">{[72,55,40,60][i]}%</div>
            </div>
          ))}
        </div>
        <div class="pt-2 border-t border-slate-100">
          <div class="h-1.5 bg-slate-200 rounded w-32 mb-1"></div>
          <div class="h-1.5 bg-slate-200 rounded w-24"></div>
        </div>
      </div>
    )}

    {type === 'riskregister' && (
      <div class="space-y-1.5">
        <div class="grid grid-cols-6 gap-1 pb-1 border-b border-slate-200">
          {['Risk', 'Owner', 'L', 'I', 'RAG', 'Action'].map((h) => (
            <div class="h-1.5 bg-slate-400 rounded"></div>
          ))}
        </div>
        {[
          ['red', 85],
          ['amber', 70],
          ['amber', 60],
          ['green', 40],
          ['green', 55],
        ].map(([rag, w]) => (
          <div class="grid grid-cols-6 gap-1 items-center">
            <div class="col-span-1 h-1.5 bg-slate-200 rounded" style={`width:${w}%`}></div>
            <div class="h-1.5 bg-slate-200 rounded w-10"></div>
            <div class="h-3 w-3 rounded" style={`background:${rag === 'red' ? '#ef4444' : rag === 'amber' ? '#f59e0b' : '#22c55e'}`}></div>
            <div class="h-3 w-3 rounded" style={`background:${rag === 'red' ? '#ef4444' : rag === 'amber' ? '#f59e0b' : '#22c55e'}`}></div>
            <div class="h-3 w-3 rounded" style={`background:${rag === 'red' ? '#ef4444' : rag === 'amber' ? '#f59e0b' : '#22c55e'}`}></div>
            <div class="h-1.5 bg-slate-200 rounded"></div>
          </div>
        ))}
      </div>
    )}

    {type === 'costbenefit' && (
      <div class="space-y-2">
        <div class="grid grid-cols-4 gap-1 pb-1 border-b border-slate-200">
          <div class="col-span-2 h-1.5 bg-slate-400 rounded"></div>
          {['Yr 1', 'Yr 2', 'Yr 3'].map((y) => (
            <div class="h-1.5 bg-slate-300 rounded"></div>
          ))}
        </div>
        {['Implementation', 'Licensing', 'Support'].map((row, i) => (
          <div class="grid grid-cols-4 gap-1 items-center">
            <div class="col-span-2 h-1.5 bg-slate-200 rounded"></div>
            <div class="h-3 bg-red-100 rounded flex items-center justify-end pr-1"><span style="font-size:7px" class="text-red-600 font-medium">{['450k','120k','80k'][i]}</span></div>
            <div class="h-3 bg-red-50 rounded flex items-center justify-end pr-1"><span style="font-size:7px" class="text-red-500 font-medium">{['0','120k','80k'][i]}</span></div>
            <div class="h-3 bg-red-50 rounded flex items-center justify-end pr-1"><span style="font-size:7px" class="text-red-500 font-medium">{['0','120k','80k'][i]}</span></div>
          </div>
        ))}
        <div class="border-t border-slate-200 pt-1.5 grid grid-cols-4 gap-1">
          <div class="col-span-2 h-1.5 bg-slate-800 rounded w-16"></div>
          {['-450k', '+280k', '+520k'].map((val, i) => (
            <div class:list={['h-3 rounded flex items-center justify-end pr-1', i === 0 ? 'bg-red-100' : 'bg-emerald-100']}>
              <span style="font-size:7px" class:list={['font-bold', i === 0 ? 'text-red-700' : 'text-emerald-700']}>{val}</span>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>

  <!-- Watermark label -->
  <div class="absolute bottom-2 right-2 text-xs font-medium text-slate-300" style="font-size:9px">
    Preview
  </div>
</div>

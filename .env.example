# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA_ID=

# Site URL (used for canonical URLs and OG metadata)
PUBLIC_SITE_URL=https://skylavelle.com.au

# Beehiiv - Publication ID for the embedded signup widget
PUBLIC_BEEHIIV_PUBLICATION_ID=

# Beehiiv - Direct signup page URL (e.g. https://your-publication.beehiiv.com/subscribe)
# When set, all newsletter and resource download CTAs link here
PUBLIC_BEEHIIV_SIGNUP_URL=

# Lemon Squeezy checkout URLs (format: https://{store}.lemonsqueezy.com/buy/{variant_id})
PUBLIC_LS_PROJECT_RECOVERY_PACK=
PUBLIC_LS_BUSINESS_CASE_PACK=
PUBLIC_LS_PROCUREMENT_PACK=
PUBLIC_LS_STEERING_COMMITTEE_PACK=

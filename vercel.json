{
  "redirects": [
    { "source": "/templates", "destination": "https://lavelleptyltd.com.au/templates", "permanent": true },
    { "source": "/templates/project-recovery-pack", "destination": "https://lavelleptyltd.com.au/templates/project-recovery-pack", "permanent": true },
    { "source": "/templates/enterprise-technology-business-case-pack", "destination": "https://lavelleptyltd.com.au/templates/business-case-pack", "permanent": true },
    { "source": "/templates/procurement-evaluation-pack", "destination": "https://lavelleptyltd.com.au/templates/procurement-pack", "permanent": true },
    { "source": "/templates/steering-committee-reporting-pack", "destination": "https://lavelleptyltd.com.au/templates/steering-committee-pack", "permanent": true },
    { "source": "/templates/business-case-pack", "destination": "https://lavelleptyltd.com.au/templates/business-case-pack", "permanent": true },
    { "source": "/templates/steering-committee-pack", "destination": "https://lavelleptyltd.com.au/templates/steering-committee-pack", "permanent": true },
    { "source": "/templates/procurement-pack", "destination": "https://lavelleptyltd.com.au/templates/procurement-pack", "permanent": true },
    { "source": "/thank-you/product", "destination": "https://lavelleptyltd.com.au/thank-you/product", "permanent": true },
    { "source": "/free-tools", "destination": "https://lavelleptyltd.com.au/free-tools", "permanent": true },
    { "source": "/free-resources", "destination": "https://lavelleptyltd.com.au/free-tools", "permanent": true },

    { "source": "/pmo-resources", "destination": "https://lavelleptyltd.com.au/pmo-resources", "permanent": true },
    { "source": "/project-recovery-checklist", "destination": "https://lavelleptyltd.com.au/free-tools/project-recovery-checklist", "permanent": true },
    { "source": "/delivery-framework", "destination": "https://lavelleptyltd.com.au/delivery-framework", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:jpg|jpeg|png|webp|avif|gif|svg|ico|woff|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/pagefind/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
